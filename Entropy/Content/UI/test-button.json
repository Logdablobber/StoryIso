{
	"$schema": "./UISchema.json",
	"Name": "test button",
	"Position": [10, 10],
	"Scale": 1,
	"Parts": 
	[
		{
			"Name": "background",
			"Position": [0, 0],
			"Content": {
				"$type": "polygon",
				"Vertices": [
					[0, 0],
					[0, 50],
					[50, 50],
					[50, 0]
				],
				"color": "#ff0000ff"
			},
			"Visible": true
		},
		{
			"Name": "button",
			"Position": [0, 0],
			"Content": {
				"$type": "button",
				"Size": [50, 50],
				"OnLeftRelease": "Test Button"
			}
		},
		{
			"Name": "Text",
			"Position": [2, 2],
			"Content": {
				"$type": "text",
				"font": "ibmbios",
				"fontSize": 1,
				"Size": [46, 46],
				"text": "{counter}",
				"hAlignment": "Center",
				"vAlignment": "Center",
				"WrapText": false
			}
		}
	]
}
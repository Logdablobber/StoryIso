#UpdateSelectorPosition

ResetAnimation("Dialogue.Options.OptionSelector.image", Blinking)

#IF dialogueSelectorIndex == 0
	let float new_y = GetFloatAttr("Dialogue.Options.Option1", "local_y")

	SetAttr("Dialogue.Options.OptionSelector", "y", new_y)

#ELIF dialogueSelectorIndex == 1
	let float new_y1 = GetFloatAttr("Dialogue.Options.Option2", "local_y")

	SetAttr("Dialogue.Options.OptionSelector", "y", new_y1)

#ELSE
	let float new_y2 = GetFloatAttr("Dialogue.Options.Option3", "local_y")

	SetAttr("Dialogue.Options.OptionSelector", "y", new_y2)
#ENDIF
#MoveSelectorUp

#IF !GetBoolAttr("Dialogue.Options.Option1", "visible")
	#RETURN
#ENDIF

#IF !GetBoolAttr("Dialogue.Options.Option2", "visible")
	set dialogueSelectorIndex = 0

#ELIF dialogueSelectorIndex == 0 || !GetBoolAttr("Dialogue.Options.Option3", "visible") 
	set dialogueSelectorIndex = 1

#ELSE
	set dialogueSelectorIndex = 2

#ENDIF

RunScene("UpdateSelectorPosition")
#startup
.DefineVar int, testInt, 12 + 3 * 2
.DefineVar bool, testSuccess, true

.DefineVar string, testString, "Starting tests!"
.Print testString

.SetVar testString, "String variable setting & retrieval successful!"
#IF !(testString == "String variable setting & retrieval successful!") 
	.Print "Variable Setting Failed"
	.SetVar testSuccess, false
#ELSE
	.Print testString
#ENDIF

#IF !("Hello, World!" == "Hello, World!")
	.Print "String Equality Failed"
	.SetVar testSuccess, false
#ENDIF

#IF !((3 + 3) ^ 3 != 16)
	.Print "Math or Int Inequalities Failed"
	.SetVar testSuccess, false
#ENDIF

#IF (1 != 1)
	.Print "Inequalities Failed"
	.SetVar testSuccess, false
#ENDIF

#IF false
	.Print "Boolean Logic Failed"
	.SetVar testSuccess, false
#ENDIF

#IF !true
	.Print "Negation Failed"
	.SetVar testSuccess, false
#ENDIF

#IF testInt != 18
	.Print "Variable retrieval failed"
	.SetVar testSuccess, false
#ENDIF

#IF testSuccess
	.Print "All tests successful!"
#ENDIF

#LOOP testLoop 3
	.Print "Looped!"

#ENDLOOP testLoop

.Print "End of tests"
// comment example
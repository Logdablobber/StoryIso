#Open Wall

Print("Toggled Off!")

// Interaction
SetTile(InteractionTileLayer, 33, 7, 7)

// middle row
RemoveTile(WallLayer, 12, 7)
RemoveTile(WallLayer, 13, 7)
RemoveTile(WallLayer, 14, 7)

// top row
SetRow(WallLayer, 12, 6, [3, 4, 4])

// bottom row
SetRow(WallLayer, 12, 8, [9, 25, 25])

// disable collider
SetCollider("removable1", false)

RunDialogue("wall open")

set counter += 1
Print(concat("Counter: ", counter))
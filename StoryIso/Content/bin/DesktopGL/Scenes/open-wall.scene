#Open Wall

.Print "Toggled Off!"

// Interaction
.SetTile InteractionTileLayer 33 7 7

// middle row
.RemoveTile WallLayer 12 7
.RemoveTile WallLayer 13 7
.RemoveTile WallLayer 14 7

// top row
.SetTile WallLayer 3 12 6
.SetTile WallLayer 4 13 6
.SetTile WallLayer 4 14 6

// bottom row
.SetTile WallLayer 9 12 8
.SetTile WallLayer 25 13 8
.SetTile WallLayer 25 14 8

// disable collider
.SetCollider "removable1" false

.RefreshMap

.RunDialogue "wall open"
#Close Wall

.Print "Toggled On!"

// Interaction Tile
.SetTile InteractionTileLayer, 34, 7, 7

// middle row
.SetRow WallLayer, 12, 7, [11, 28, 28]

// top row
.SetRow WallLayer, 12, 6, [11, 28, 28]

// bottom row
.SetRow WallLayer, 12, 8, [11, 28, 28]

// enable collider
.SetCollider "removable1", true

.RefreshMap

.RunDialogue "wall close"